{
  "name": "deterministic-api-testbed",
  "version": "0.1.0",
  "description": "Deterministic API test bed for prompt-driven QA automation demos",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "playwright test",
    "test:api": "playwright test tests/api.spec.ts"
  },
  "keywords": [
    "api",
    "testing",
    "playwright",
    "qa",
    "automation",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}